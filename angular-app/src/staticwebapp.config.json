{
  "platform": {
    "apiRuntime": "node:20"
  },
  "globalHeaders": {
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "trailingSlash": "auto",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/assets/*", "/*.{css,js,map,png,jpg,jpeg,gif,svg,ico,webp}"]
  }
}
